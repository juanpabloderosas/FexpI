n <- 1000
limitame <- max(n*0.05*dnorm(x = seq(9.4,10.2,0.01), mean = 9.800,sd = 1/10))
limitame <- limitame + sqrt(limitame)
limitame2 <-max(n*0.01*dnorm(x = seq(9.4,10.2,0.01), mean = 9.800,sd = 1/sqrt(1000)))
limitame2 <- limitame2 + sqrt(limitame2)
mm <- vector(mode = "numeric", length = n)
mm2 <- vector(mode = "numeric", length = n)
ani.options(interval = 0.085, nmax = 1000 )
saveGIF({
for(i in 1:n){
par(mfrow=c(2,2))    # set the plotting area into a 1*2 array
muestra <- rnorm(100, mean = 9.8, sd = 1)
muestra <- muestra[muestra < 9.8+3.5 & muestra > 9.8 -3.5]
mm[i] <- mean(muestra)
hist(muestra, col = "Deepskyblue3", breaks = 9.8 + seq(-3.5,3.5,0.2),border = NA, main = "100 Medidas\n Media Muestral(Rojo)", xlab = TeX("$ g \\; (m/s^2)$") )
abline(v = mean(muestra), col = "Red4", lwd = 2)
hist(mm[1:i], main=paste(i, " Medias Muestrales \n(100 valores)"),ylim = c(0,limitame) ,breaks = seq(9.4,10.2,0.05), col = "Red4", border = NA, xlab = TeX("$\\bar{g} \\; (m/s^2)$"))
lines(x = seq(9.4,10.2,0.01), y = (n*0.05*dnorm(x = seq(9.4,10.2,0.01), mean = 9.800,sd = 1/10)),lwd = 3)
muestra2 <- rnorm(1000, mean = 9.8, sd = 1)
muestra2 <- muestra2[muestra2 < 9.8+3.5 & muestra2 > 9.8 -3.5]
mm2[i] <- mean(muestra2)
hist(muestra2, col = "Deepskyblue4", breaks = 9.8 + seq(-3.5,3.5,0.2),border = NA, main = "1000 Medidas\n Media Muestral(Rojo)", xlab = TeX("$ g \\; (m/s^2)$") )
abline(v = mean(muestra2), col = "Red2", lwd = 2)
hist(mm2[1:i], main=paste(i, " Medias Muestrales \n(1000 valores)"),ylim = c(0,limitame2) ,breaks = seq(9.4,10.2,0.01), col = "Red2", border = NA, xlab = TeX("$\\bar{g} \\; (m/s^2)$"))
lines(x = seq(9.4,10.2,0.01), y = (n*0.01*dnorm(x = seq(9.4,10.2,0.01), mean = 9.800,sd = 1/sqrt(1000))),lwd = 3)
}
