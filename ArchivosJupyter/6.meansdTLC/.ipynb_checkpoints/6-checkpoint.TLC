   "source": [
    "sigma <- sqrt(3)/(3*sqrt(6))\n",
    "ghme <- ghm +   geom_errorbarh(aes(xmax = mm + c(1:3)* sigma, xmin = mm - c(1:3)* sigma, y = 0.78,height = c(.3,.2,.1)), lwd = 1, colour = \"red3\")\n",
    "show(ghme)"
   ]
