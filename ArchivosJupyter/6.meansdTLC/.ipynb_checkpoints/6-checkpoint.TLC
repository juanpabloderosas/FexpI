   "source": [
    "n <- 10000; an <- rnorm(n = n, mean = 3, sd = 0.5) ;grn <- ggplot() + geom_point(aes(x = 1:n, y = an), size = 3,alpha = 0.2) + temajuan3\n",
    "show(grn)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {
    "slideshow": {
     "slide_type": "slide"
    }
   },
   "source": [
    "Un histograma de lo anterior"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 214,
   "metadata": {
    "slideshow": {
     "slide_type": "slide"
    }
   },
   "outputs": [],
   "source": [
    "mi = 3; s = 0.5;\n",
    "an <- rnorm(10000, mean = mi, sd = s); x = seq(0, 5, 0.01); y <- dnorm(x = x, mean = mi, sd = s)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 215,
   "metadata": {
    "slideshow": {
     "slide_type": "skip"
    }
   },
   "outputs": [],
   "source": [
    "ghm <- ggplot() +   geom_histogram(aes(x = an, y = ..density..),colour = \"Deepskyblue4\", fill = \"Deepskyblue4\",alpha = 0.3, bins = nclass.FD(an)+3)  +\n",
    "geom_line(aes(x = x, y = y)) +   \n",
    "xlab(\"x\") + ylab(\"Densidad de Probabilidad\") + ggtitle(\"Histograma - Distribución Normal\") +   temajuan3"
   ]
  },
