   "source": [
    "medidas;cat(bold(\"La media muestral es mm =\",mean(medidas)), \"\\n\");cat(bold(\"la desviación estándar de la muestra es sd = \", sd(medidas)));cat(\"\\n \\n\");cat(bold(red(\"Entonces la media muestral verdadera está en una distribución normal,\n",
    "que tiene una desviación estándar sigma =\", sd(medidas)/sqrt(length(medidas)) )));cat(\"\\n \\n\")\n",
    "cat(bold(blue(\"Y el valor que calculamos de  media muestralmm = \", mm, \"contendrá \n",
    "a la media verdadera = \", 5, \"si le agregamos incertezas de 1, 2,3,4,5 desviaciones\n",
    "estándar de la distribución normal donde vive\"   )))"
   ]
