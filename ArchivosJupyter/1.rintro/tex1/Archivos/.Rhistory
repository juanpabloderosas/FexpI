method.args = list(start = c(J = 690.57987,v = 1.22, D = 32),
lower = c(J = 10,v = 0.01, D = 2),
upper = c(J = 1000,v = 10, D = 50),
algorithm = "port"),
fullrange = T) +
# ylab(TeX('Concentración $^{137}Cs$ $ (Bq \\, kg^{-1}) $')) +
#  xlab(TeX('Prof. Másica $Kg \\, m^{-2}$')) +
scale_x_continuous(limits= c(-0.25, max(ref$mpm)+15), breaks = seq(0,max(ref$mpm)+20,10), seq(0,max(ref$mpm)+20,10)) +
theme(
axis.title.x = element_text(size = 8)
)
show(gpp)
gpp <- ggplot() +
geom_col(aes(x = ref$mpm, y = ref$Ccs), width = ref$pm, colour = NA, fill = "Blue", alpha = 0.2,lwd = 1) +
geom_ribbon(aes(x = ref$mpm, ymin = ref$lowfit, ymax = ref$upfit),
colour = NA, alpha = 0.1) +
geom_pointrange(aes(x = ref$mpm, y = ref$Ccs),
ymin = ref$Ccs - ref$eCcs, ymax = ref$Ccs + ref$eCcs,
colour = "black", size = 1.1, fatten = 2) +
geom_smooth(aes(x = ref$mpm, y = ref$Ccs), show.legend = T,
colour = "Blue", se = F,
method = "nls",
formula = y ~ f(x,J,v,D),
method.args = list(start = c(J = 690.57987,v = 1.22, D = 32),
lower = c(J = 10,v = 0.01, D = 2),
upper = c(J = 1000,v = 10, D = 50),
algorithm = "port"),
fullrange = T) +
# ylab(TeX('Concentración $^{137}Cs$ $ (Bq \\, kg^{-1}) $')) +
#  xlab(TeX('Prof. Másica $Kg \\, m^{-2}$')) +
scale_x_continuous(limits= c(-0.25, max(ref$mpm)+15), breaks = seq(0,max(ref$mpm)+20,10), seq(0,max(ref$mpm)+20,10)) +
theme(
axis.title.x = element_text(size = 8)
)
show(gpp)
x <- rnorm(1000,mean = 4, sd = 0.5)
y <- rnorm(1000,mean = 6, sd = 0.5)
sum((x - mean(x)) * (y-mean(y)) )
(x - mean(x)) * (y-mean(y))
hist(x)
hist(y)
(x - mean(x)) * (y-mean(y))
sum((x - mean(x)) * (y-mean(y)) )
sum( ((x - mean(x)) * (y-mean(y))) )
co <- ((x - mean(x)) * (y-mean(y)))
sum(co)
sum(co/length(co))
y <- x*2
co <- ((x - mean(x)) * (y-mean(y)))
sum(co/length(co))
y <- x*2+2
co <- ((x - mean(x)) * (y-mean(y)))
sum(co/length(co))
y <- x*2+10
co <- ((x - mean(x)) * (y-mean(y)))
sum(co/length(co))
y <- x*3+10
co <- ((x - mean(x)) * (y-mean(y)))
sum(co/length(co))
y <- -x*3+10
co <- ((x - mean(x)) * (y-mean(y)))
sum(co/length(co))
y <- -x*3
sum(co/length(co))
