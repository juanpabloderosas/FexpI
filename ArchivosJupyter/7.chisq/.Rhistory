segments(x0 = media - s, x1 = media + s, y0 = 0.7,y1 = 0.7, lwd = 2, col = "Red3") #s
hist(s[1:i], main=paste(i, "Y"), breaks = seq(0,15,1) ,xlim = c(0, max(xc)),ylim = c(0,max(1000*cpdf)) , col = "Red3", border = NA, xlab = TeX("$\\bar{g} \\; (m/s^2)$"))
