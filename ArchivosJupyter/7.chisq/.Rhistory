saveGIF({
for(i in 1:n){
par(mfrow=c(2,1))
muestra <- rnorm(n = m, mean = media, sd = sigma)
s[i] <- (m-1)*sd(muestra)^2
hist(muestra, col = "Deepskyblue3", ylim = c(0,2), xlim = c(2,8),border = NA, breaks = seq(2,8,0.5),main = "6 Medidas\n sd Muestral(Rojo)", probability = T)
lines(x = x, y = pdf, lty = 2, lwd = 0.75)
segments(x0 = media, x1 = media, y0 = 0,y1 = 3.5, lty = 2) #media
segments(x0 = media - sigma, x1 = media + sigma, y0 = 1.6,y1 = 1.6) #sigma
segments(x0 = media - s, x1 = media + s, y0 = 1.4,y1 = 1.4, lwd = 2, col = "Red3") #s
hist(s[1:i], main=paste(i, "Y"), breaks = seq(0,18,1) ,xlim = c(0, max(xc)),ylim = c(0,max(1000*cpdf)) , col = "Red3", border = NA, xlab = TeX("$Y =\\; 5s^2/ \\sigma ^2$"))
lines(x = xc, y = 1000*cpdf,lwd = 3)
}
}, convert = 'gm convert',ani.width = 300, ani.height = 400 , movie.name = 'chisq.gif') #close the animation builder
